<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_branch_transfer_return_wizard" model="ir.ui.view">
        <field name="name">branch.transfer.return.wizard.form</field>
        <field name="model">branch.transfer.return.wizard</field>
        <field name="arch" type="xml">
            <form string="Report Damaged Products">
                <sheet>
                    <group>
                        <field name="request_id" readonly="1"/>
                        <field name="return_reason" placeholder="Enter reason for return/damage..."/>
                    </group>
                    <field name="line_ids" widget="one2many">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="product_uom_id"/>
                            <field name="qty_requested" string="Original Qty"/>
                            <field name="return_qty" string="Damaged Qty"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirm_return"
                            string="Send Notification"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>